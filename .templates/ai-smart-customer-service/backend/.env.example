# Server Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# Database Configuration
# For development, update with your actual PostgreSQL credentials
# For testing, DATABASE_URL has a default value and can be omitted
DATABASE_URL="postgresql://postgres:Tencent2025@localhost:5432/genie?schema=public"

# CORS Configuration
# Set to "*" to allow all origins (default), or specify a URL like "http://localhost:5173"
# WARNING: Using "*" disables credentials (cookies, authorization headers)
CORS_ORIGIN=*

# Logging Configuration
# Log levels: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
