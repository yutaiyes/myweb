[[app]]
name = "docker"
cmd = "docker stats"
autoRun = true
port = 3000

[[app]]
name = "frontend"
cmd = "cd frontend && npm audit fix && npm install --production=false && npm run dev"
autoRun = true
port = 5173

[[app]]
name = "backend"
cmd = "cd backend && npm audit fix && npm install --production=false && npm run dev"
autoRun = true
port = 3000
