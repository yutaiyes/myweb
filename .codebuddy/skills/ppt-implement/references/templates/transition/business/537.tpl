<!-- Template: 商务风-品牌竖线 (Transition #537) -->
<div class="w-[1440px] h-[810px] shadow-2xl relative overflow-hidden bg-white">
    <div class="w-[1350px] h-[720px] absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 relative">
        <!-- 左侧品牌色竖条 -->
        <div class="absolute left-0 top-0 bottom-0 w-[6px] bg-gradient-to-b from-blue-600 via-blue-500 to-indigo-600"></div>

        <!-- 右上角几何装饰 -->
        <div class="absolute top-0 right-0 w-[280px] h-[280px] opacity-[0.03]">
            <div class="absolute top-0 right-0 w-full h-full border-r-[3px] border-t-[3px] border-slate-900"></div>
            <div class="absolute top-8 right-8 w-[calc(100%-32px)] h-[calc(100%-32px)] border-r-[2px] border-t-[2px] border-slate-900"></div>
        </div>

        <!-- 底部细线 -->
        <div class="absolute bottom-0 left-[6px] right-0 h-px bg-slate-200"></div>

        <!-- 内容区域 -->
        <div class="relative z-10 h-full flex items-center pl-20">
            <div>
                <!-- 章节标签 -->
                <div class="flex items-center gap-3 mb-8">
                    <div class="w-10 h-px bg-blue-600"></div>
                    <span class="text-xs font-semibold tracking-[0.3em] text-blue-600 uppercase">Section</span>
                </div>

                <!-- 编号 -->
                <div class="text-8xl font-bold text-slate-900 mb-2 leading-none" style="font-variant-numeric: tabular-nums;">01</div>

                <!-- 分隔线 -->
                <div class="w-16 h-[3px] bg-blue-600 my-6"></div>

                <!-- 标题 -->
                <h1 class="text-4xl font-bold text-slate-900 mb-4 tracking-tight">项目背景</h1>

                <!-- 副标题 -->
                <p class="text-lg text-slate-500 font-light">了解项目的起源与目标</p>
            </div>
        </div>

        <!-- 右下角页码区域 -->
        <div class="absolute bottom-8 right-8 flex items-center gap-3">
            <div class="flex gap-1">
                <div class="w-6 h-1 bg-blue-600 rounded-full"></div>
                <div class="w-3 h-1 bg-slate-200 rounded-full"></div>
                <div class="w-3 h-1 bg-slate-200 rounded-full"></div>
                <div class="w-3 h-1 bg-slate-200 rounded-full"></div>
            </div>
        </div>
    </div>
</div>
