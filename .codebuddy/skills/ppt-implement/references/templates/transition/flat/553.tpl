<!-- Template: 扁平风-瑞士构成 (Transition #553) -->
            <div class="w-[1440px] h-[810px] shadow-2xl relative overflow-hidden bg-slate-50">
                <div class="w-[1350px] h-[720px] absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">

                    <!-- 左侧大色块 -->
                    <div class="absolute top-0 left-0 w-[480px] h-full bg-slate-900"></div>

                    <!-- 左侧色块内 - 网格纹理 -->
                    <svg class="absolute top-0 left-0 w-[480px] h-full opacity-[0.05]" xmlns="http://www.w3.org/2000/svg">
                        <pattern id="t553-grid" width="40" height="40" patternUnits="userSpaceOnUse">
                            <rect width="40" height="40" fill="none" stroke="#ffffff" stroke-width="0.5"/>
                        </pattern>
                        <rect width="100%" height="100%" fill="url(#t553-grid)"/>
                    </svg>

                    <!-- 右上角强调色块 -->
                    <div class="absolute top-0 right-0 w-[260px] h-[200px] bg-rose-500"></div>

                    <!-- 右下角次色块 -->
                    <div class="absolute bottom-0 right-0 w-[400px] h-[120px] bg-amber-400"></div>

                    <!-- 中间衔接竖条 -->
                    <div class="absolute top-[200px] right-[260px] w-[12px] h-[400px] bg-rose-500"></div>

                    <!-- 左侧大色块内 - 超大编号 -->
                    <div class="absolute top-[80px] left-[40px] text-[200px] font-black text-white opacity-[0.06] leading-none" style="font-family: 'Helvetica Neue', Arial, sans-serif;">01</div>

                    <!-- 左侧色块内 - 内容 -->
                    <div class="absolute top-[180px] left-[60px] w-[360px]">
                        <!-- 标签 -->
                        <div class="flex items-center gap-3 mb-8">
                            <div class="w-[40px] h-[3px] bg-rose-500"></div>
                            <span class="text-xs font-bold tracking-[0.3em] text-slate-400 uppercase" style="font-family: 'Helvetica Neue', Arial, sans-serif;">Section</span>
                        </div>

                        <!-- 编号 -->
                        <div class="text-[80px] font-black text-white leading-none mb-6" style="font-family: 'Helvetica Neue', Arial, sans-serif;">01</div>

                        <!-- 分隔线 -->
                        <div class="w-[60px] h-[3px] bg-rose-500 mb-8"></div>

                        <!-- 标题 -->
                        <h1 class="text-[36px] font-bold text-white mb-4 leading-tight" style="font-family: 'Helvetica Neue', Arial, sans-serif;">{{title}}</h1>

                        <!-- 副标题 -->
                        <p class="text-base text-slate-400 leading-relaxed">{{subtitle}}</p>
                    </div>

                    <!-- 左侧底部装饰 -->
                    <div class="absolute bottom-[40px] left-[60px] flex items-center gap-4">
                        <div class="w-3 h-3 bg-rose-500"></div>
                        <div class="w-3 h-3 bg-amber-400"></div>
                        <div class="w-3 h-3 border-2 border-slate-500"></div>
                        <div class="w-3 h-3 bg-slate-600"></div>
                    </div>

                    <!-- 右侧区域 - 装饰元素 -->
                    <!-- 右上色块内文字 -->
                    <div class="absolute top-[60px] right-[60px] text-right">
                        <div class="text-[72px] font-black text-white opacity-20 leading-none" style="font-family: 'Helvetica Neue', Arial, sans-serif;">CH</div>
                    </div>

                    <!-- 中央右侧 - 大圆环装饰 -->
                    <div class="absolute top-[240px] right-[120px]">
                        <div class="w-[280px] h-[280px] rounded-full border-[16px] border-slate-200 opacity-40"></div>
                        <div class="absolute top-[40px] left-[40px] w-[200px] h-[200px] rounded-full border-[3px] border-slate-300 opacity-30"></div>
                    </div>

                    <!-- 右侧中央 - 小数据块 -->
                    <div class="absolute top-[320px] right-[80px] text-right">
                        <div class="text-[11px] font-bold tracking-[0.2em] text-slate-400 uppercase mb-1" style="font-family: 'Helvetica Neue', Arial, sans-serif;">Progress</div>
                        <div class="flex items-center gap-1 justify-end">
                            <div class="w-6 h-1 bg-rose-500"></div>
                            <div class="w-6 h-1 bg-rose-500"></div>
                            <div class="w-6 h-1 bg-rose-500"></div>
                            <div class="w-6 h-1 bg-slate-200"></div>
                            <div class="w-6 h-1 bg-slate-200"></div>
                        </div>
                    </div>

                    <!-- 右下色块上文字 -->
                    <div class="absolute bottom-[40px] right-[60px]">
                        <div class="text-sm font-bold text-slate-900 tracking-[0.15em] uppercase" style="font-family: 'Helvetica Neue', Arial, sans-serif;">Transition</div>
                    </div>

                    <!-- 顶部横线 -->
                    <div class="absolute top-0 left-[480px] right-[260px] h-[3px] bg-slate-200"></div>

                    <!-- 点阵装饰 - 右侧中下 -->
                    <div class="absolute bottom-[160px] right-[440px]" style="display: grid; grid-template-columns: repeat(4, 8px); gap: 8px;">
                        <div class="w-1.5 h-1.5 rounded-full bg-slate-300"></div>
                        <div class="w-1.5 h-1.5 rounded-full bg-slate-300"></div>
                        <div class="w-1.5 h-1.5 rounded-full bg-slate-300"></div>
                        <div class="w-1.5 h-1.5 rounded-full bg-slate-300"></div>
                        <div class="w-1.5 h-1.5 rounded-full bg-slate-300"></div>
                        <div class="w-1.5 h-1.5 rounded-full bg-slate-300"></div>
                        <div class="w-1.5 h-1.5 rounded-full bg-slate-300"></div>
                        <div class="w-1.5 h-1.5 rounded-full bg-slate-300"></div>
                        <div class="w-1.5 h-1.5 rounded-full bg-slate-300"></div>
                        <div class="w-1.5 h-1.5 rounded-full bg-slate-300"></div>
                        <div class="w-1.5 h-1.5 rounded-full bg-slate-300"></div>
                        <div class="w-1.5 h-1.5 rounded-full bg-slate-300"></div>
                    </div>

                </div>
            </div>
