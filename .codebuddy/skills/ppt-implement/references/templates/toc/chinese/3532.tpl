<!-- 
模板ID: 3532
模板名称: 中国风-梅兰竹菊
适用场景: 雅致中国风主题目录页
设计特点: 四君子水墨SVG,竖排楷体,宣纸质感,文人雅集美学
-->
<div class="w-[1440px] h-[810px] relative overflow-hidden" style="background: #f4f0e6;">
  <!-- 宣纸纹理 -->
  <div class="absolute inset-0 opacity-[0.025] pointer-events-none" style="background-image: repeating-linear-gradient(0deg, #6b5b3e 0px, transparent 1px, transparent 3px), repeating-linear-gradient(90deg, #6b5b3e 0px, transparent 1px, transparent 5px); background-size: 3px 3px, 5px 5px;"></div>

  <!-- 外边框 -->
  <div class="absolute inset-8 pointer-events-none" style="border: 1px solid rgba(107,91,62,0.2);"></div>

  <!-- 顶部标题区 -->
  <div class="absolute top-0 left-0 w-full flex justify-center pt-10 z-20">
    <div class="flex flex-col items-center">
      <div class="flex items-center gap-6">
        <div class="w-12 h-[1px]" style="background: #6b5b3e; opacity: 0.3;"></div>
        <h1 class="text-4xl tracking-[0.4em] font-bold" style="color: #3d2512; font-family: 'KaiTi', 'STKaiti', serif;">目  录</h1>
        <div class="w-12 h-[1px]" style="background: #6b5b3e; opacity: 0.3;"></div>
      </div>
      <span class="mt-2 text-[10px] tracking-[0.6em]" style="color: #6b5b3e; opacity: 0.4;">CONTENTS</span>
    </div>
  </div>

  <!-- 四君子章节区 - 横向等分 -->
  <div class="w-full h-full flex items-center justify-center px-16 pt-8">
    <div class="flex items-stretch w-full max-w-[1300px] h-[580px]">
      
      <!-- 梅 — 第一章 -->
      <div class="flex-1 flex flex-col items-center justify-between py-10 px-4 relative" style="border-right: 1px solid rgba(107,91,62,0.12);">
        <!-- 梅花SVG -->
        <div class="w-[120px] h-[180px] flex items-center justify-center opacity-[0.15]">
          <svg viewBox="0 0 120 200" fill="none">
            <!-- 梅枝 -->
            <path d="M60,200 Q55,160 40,130 Q30,110 20,80 Q15,60 25,40" stroke="#3d2512" stroke-width="2.5" fill="none" stroke-linecap="round"/>
            <path d="M40,130 Q55,110 70,90 Q80,75 85,50" stroke="#3d2512" stroke-width="2" fill="none" stroke-linecap="round"/>
            <path d="M20,80 Q10,70 8,55" stroke="#3d2512" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <!-- 梅花 -->
            <circle cx="25" cy="38" r="8" fill="#8b2500" opacity="0.7"/>
            <circle cx="25" cy="38" r="3" fill="#c9a96e" opacity="0.6"/>
            <circle cx="85" cy="48" r="7" fill="#8b2500" opacity="0.6"/>
            <circle cx="85" cy="48" r="2.5" fill="#c9a96e" opacity="0.5"/>
            <circle cx="8" cy="53" r="6" fill="#8b2500" opacity="0.5"/>
            <circle cx="8" cy="53" r="2" fill="#c9a96e" opacity="0.5"/>
            <circle cx="50" cy="95" r="5" fill="#8b2500" opacity="0.4"/>
            <!-- 花蕾 -->
            <circle cx="70" cy="70" r="3" fill="#8b2500" opacity="0.3"/>
            <circle cx="30" cy="60" r="2.5" fill="#8b2500" opacity="0.25"/>
          </svg>
        </div>

        <!-- 章节信息 -->
        <div class="flex flex-col items-center">
          <span class="text-sm mb-3 tracking-widest" style="color: #8b2500; opacity: 0.5; font-family: 'KaiTi', 'STKaiti', serif;">梅</span>
          <div class="w-10 h-10 flex items-center justify-center mb-4" style="border: 2px solid #8b2500;">
            <span class="text-lg font-bold" style="color: #8b2500; font-family: 'KaiTi', 'STKaiti', serif;">壹</span>
          </div>
          <div class="w-[1px] h-4" style="background: #6b5b3e; opacity: 0.3;"></div>
          <h3 class="mt-3 text-xl tracking-[0.2em]" style="color: #3d2512; font-family: 'KaiTi', 'STKaiti', serif;">项目背景</h3>
          <p class="mt-2 text-xs" style="color: #8b7355; opacity: 0.6; font-family: 'KaiTi', 'STKaiti', serif;">凌寒独自开</p>
        </div>
      </div>

      <!-- 兰 — 第二章 -->
      <div class="flex-1 flex flex-col items-center justify-between py-10 px-4 relative" style="border-right: 1px solid rgba(107,91,62,0.12);">
        <!-- 兰花SVG -->
        <div class="w-[120px] h-[180px] flex items-center justify-center opacity-[0.15]">
          <svg viewBox="0 0 120 200" fill="none">
            <!-- 兰叶 -->
            <path d="M60,200 Q45,150 30,100 Q20,60 35,20" stroke="#2d5016" stroke-width="2" fill="none" stroke-linecap="round"/>
            <path d="M60,200 Q70,140 85,90 Q95,50 80,15" stroke="#2d5016" stroke-width="2" fill="none" stroke-linecap="round"/>
            <path d="M60,200 Q50,170 55,130 Q58,100 50,70" stroke="#2d5016" stroke-width="1.8" fill="none" stroke-linecap="round"/>
            <!-- 兰花 -->
            <path d="M35,20 Q30,12 35,8 Q40,4 42,12 Q44,4 48,8 Q52,12 47,20 Q42,16 35,20Z" fill="#2d5016" opacity="0.5"/>
            <path d="M80,15 Q75,7 80,3 Q85,-1 87,7 Q89,-1 93,3 Q97,7 92,15 Q87,11 80,15Z" fill="#2d5016" opacity="0.4"/>
            <circle cx="41" cy="14" r="1.5" fill="#c9a96e" opacity="0.6"/>
            <circle cx="86" cy="9" r="1.5" fill="#c9a96e" opacity="0.5"/>
          </svg>
        </div>

        <div class="flex flex-col items-center">
          <span class="text-sm mb-3 tracking-widest" style="color: #2d5016; opacity: 0.5; font-family: 'KaiTi', 'STKaiti', serif;">兰</span>
          <div class="w-10 h-10 flex items-center justify-center mb-4" style="border: 2px solid #2d5016;">
            <span class="text-lg font-bold" style="color: #2d5016; font-family: 'KaiTi', 'STKaiti', serif;">贰</span>
          </div>
          <div class="w-[1px] h-4" style="background: #6b5b3e; opacity: 0.3;"></div>
          <h3 class="mt-3 text-xl tracking-[0.2em]" style="color: #3d2512; font-family: 'KaiTi', 'STKaiti', serif;">核心功能</h3>
          <p class="mt-2 text-xs" style="color: #8b7355; opacity: 0.6; font-family: 'KaiTi', 'STKaiti', serif;">幽兰生空谷</p>
        </div>
      </div>

      <!-- 竹 — 第三章 -->
      <div class="flex-1 flex flex-col items-center justify-between py-10 px-4 relative" style="border-right: 1px solid rgba(107,91,62,0.12);">
        <!-- 竹SVG -->
        <div class="w-[120px] h-[180px] flex items-center justify-center opacity-[0.15]">
          <svg viewBox="0 0 120 200" fill="none">
            <!-- 竹竿 -->
            <line x1="50" y1="200" x2="50" y2="10" stroke="#2d4a1e" stroke-width="3" stroke-linecap="round"/>
            <line x1="50" y1="160" x2="50" y2="158" stroke="#2d4a1e" stroke-width="6" opacity="0.3"/>
            <line x1="50" y1="120" x2="50" y2="118" stroke="#2d4a1e" stroke-width="6" opacity="0.3"/>
            <line x1="50" y1="80" x2="50" y2="78" stroke="#2d4a1e" stroke-width="6" opacity="0.3"/>
            <!-- 竹叶 -->
            <path d="M50,80 Q30,60 15,50" stroke="#2d4a1e" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M50,80 Q25,70 10,65" stroke="#2d4a1e" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M50,80 Q35,55 25,40" stroke="#2d4a1e" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M50,40 Q70,25 90,15" stroke="#2d4a1e" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M50,40 Q75,30 95,30" stroke="#2d4a1e" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M50,120 Q70,105 85,95" stroke="#2d4a1e" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M50,120 Q65,115 80,115" stroke="#2d4a1e" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <!-- 副竹竿 -->
            <line x1="75" y1="200" x2="75" y2="60" stroke="#2d4a1e" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
          </svg>
        </div>

        <div class="flex flex-col items-center">
          <span class="text-sm mb-3 tracking-widest" style="color: #2d4a1e; opacity: 0.5; font-family: 'KaiTi', 'STKaiti', serif;">竹</span>
          <div class="w-10 h-10 flex items-center justify-center mb-4" style="border: 2px solid #2d4a1e;">
            <span class="text-lg font-bold" style="color: #2d4a1e; font-family: 'KaiTi', 'STKaiti', serif;">叁</span>
          </div>
          <div class="w-[1px] h-4" style="background: #6b5b3e; opacity: 0.3;"></div>
          <h3 class="mt-3 text-xl tracking-[0.2em]" style="color: #3d2512; font-family: 'KaiTi', 'STKaiti', serif;">技术架构</h3>
          <p class="mt-2 text-xs" style="color: #8b7355; opacity: 0.6; font-family: 'KaiTi', 'STKaiti', serif;">虚心有节存</p>
        </div>
      </div>

      <!-- 菊 — 第四章 -->
      <div class="flex-1 flex flex-col items-center justify-between py-10 px-4 relative">
        <!-- 菊花SVG -->
        <div class="w-[120px] h-[180px] flex items-center justify-center opacity-[0.15]">
          <svg viewBox="0 0 120 200" fill="none">
            <!-- 菊茎 -->
            <path d="M60,200 Q55,160 60,120 Q62,100 58,80" stroke="#8b6914" stroke-width="2" fill="none" stroke-linecap="round"/>
            <path d="M60,140 Q40,130 25,135" stroke="#8b6914" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M60,160 Q80,150 90,155" stroke="#8b6914" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <!-- 菊花瓣 -->
            <ellipse cx="58" cy="55" rx="4" ry="18" fill="#8b6914" opacity="0.5" transform="rotate(0 58 55)"/>
            <ellipse cx="58" cy="55" rx="4" ry="18" fill="#8b6914" opacity="0.5" transform="rotate(30 58 55)"/>
            <ellipse cx="58" cy="55" rx="4" ry="18" fill="#8b6914" opacity="0.5" transform="rotate(60 58 55)"/>
            <ellipse cx="58" cy="55" rx="4" ry="18" fill="#8b6914" opacity="0.5" transform="rotate(90 58 55)"/>
            <ellipse cx="58" cy="55" rx="4" ry="18" fill="#8b6914" opacity="0.5" transform="rotate(120 58 55)"/>
            <ellipse cx="58" cy="55" rx="4" ry="18" fill="#8b6914" opacity="0.5" transform="rotate(150 58 55)"/>
            <!-- 花心 -->
            <circle cx="58" cy="55" r="6" fill="#c9a96e" opacity="0.5"/>
            <!-- 叶 -->
            <path d="M25,135 Q20,125 28,120 Q35,128 25,135Z" fill="#2d4a1e" opacity="0.3"/>
            <path d="M90,155 Q95,145 88,140 Q82,148 90,155Z" fill="#2d4a1e" opacity="0.25"/>
          </svg>
        </div>

        <div class="flex flex-col items-center">
          <span class="text-sm mb-3 tracking-widest" style="color: #8b6914; opacity: 0.5; font-family: 'KaiTi', 'STKaiti', serif;">菊</span>
          <div class="w-10 h-10 flex items-center justify-center mb-4" style="border: 2px solid #8b6914;">
            <span class="text-lg font-bold" style="color: #8b6914; font-family: 'KaiTi', 'STKaiti', serif;">肆</span>
          </div>
          <div class="w-[1px] h-4" style="background: #6b5b3e; opacity: 0.3;"></div>
          <h3 class="mt-3 text-xl tracking-[0.2em]" style="color: #3d2512; font-family: 'KaiTi', 'STKaiti', serif;">实施计划</h3>
          <p class="mt-2 text-xs" style="color: #8b7355; opacity: 0.6; font-family: 'KaiTi', 'STKaiti', serif;">采菊东篱下</p>
        </div>
      </div>

    </div>
  </div>

  <!-- 左下印章 -->
  <div class="absolute bottom-12 left-12 w-12 h-12 flex items-center justify-center z-20" style="border: 2px solid #8b2500;">
    <span class="text-sm font-bold" style="color: #8b2500; font-family: 'KaiTi', 'STKaiti', serif;">雅</span>
  </div>

  <!-- 右下落款 -->
  <div class="absolute bottom-12 right-16 text-xs z-20" style="color: #6b5b3e; opacity: 0.4; font-family: 'KaiTi', 'STKaiti', serif;">
    四君子 · 清雅之韵
  </div>
</div>
