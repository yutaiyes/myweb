<!-- 
模板ID: 3567
模板名称: 扁平风-色块拼图
适用场景: 现代扁平风目录页
设计特点: 大色块拼图布局,纯色扁平,三列紧凑,无阴影无渐变
-->
<div class="w-[1440px] h-[810px] relative overflow-hidden bg-white">
  <!-- 左侧大色块标题区 -->
  <div class="absolute top-0 left-0 w-[420px] h-full flex flex-col justify-center items-center" style="background-color: #3b82f6;">
    <!-- 装饰圆 -->
    <div class="absolute top-12 left-12 w-20 h-20 rounded-full" style="background-color: rgba(255,255,255,0.08);"></div>
    <div class="absolute bottom-16 right-8 w-32 h-32 rounded-full" style="background-color: rgba(255,255,255,0.05);"></div>
    <div class="absolute top-1/3 right-4 w-12 h-12 rounded-full" style="background-color: rgba(255,255,255,0.06);"></div>

    <h2 class="text-5xl font-black text-white tracking-wide">目录</h2>
    <p class="mt-3 text-sm font-medium tracking-[8px] uppercase" style="color: rgba(255,255,255,0.5);">Contents</p>
    <div class="mt-6 w-12 h-1 bg-white rounded-full" style="opacity: 0.4;"></div>
  </div>

  <!-- 右侧条目区 -->
  <div class="absolute top-0 left-[420px] right-0 h-full flex flex-col justify-center px-16 py-12">
    <div class="grid grid-cols-3 gap-4">
      <!-- 条目1 -->
      <div class="px-6 py-8 rounded-2xl flex flex-col items-start" style="background-color: #eff6ff;">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center font-bold text-lg text-white" style="background-color: #3b82f6;">1</div>
        <span class="mt-4 text-base font-semibold text-gray-800">项目背景</span>
      </div>
      <!-- 条目2 -->
      <div class="px-6 py-8 rounded-2xl flex flex-col items-start" style="background-color: #fef3c7;">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center font-bold text-lg text-white" style="background-color: #f59e0b;">2</div>
        <span class="mt-4 text-base font-semibold text-gray-800">核心功能</span>
      </div>
      <!-- 条目3 -->
      <div class="px-6 py-8 rounded-2xl flex flex-col items-start" style="background-color: #fce7f3;">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center font-bold text-lg text-white" style="background-color: #ec4899;">3</div>
        <span class="mt-4 text-base font-semibold text-gray-800">技术架构</span>
      </div>
      <!-- 条目4 -->
      <div class="px-6 py-8 rounded-2xl flex flex-col items-start" style="background-color: #d1fae5;">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center font-bold text-lg text-white" style="background-color: #10b981;">4</div>
        <span class="mt-4 text-base font-semibold text-gray-800">实施计划</span>
      </div>
      <!-- 条目5 -->
      <div class="px-6 py-8 rounded-2xl flex flex-col items-start" style="background-color: #e0e7ff;">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center font-bold text-lg text-white" style="background-color: #6366f1;">5</div>
        <span class="mt-4 text-base font-semibold text-gray-800">成果展示</span>
      </div>
      <!-- 条目6 -->
      <div class="px-6 py-8 rounded-2xl flex flex-col items-start" style="background-color: #fed7aa;">
        <div class="w-11 h-11 rounded-xl flex items-center justify-center font-bold text-lg text-white" style="background-color: #f97316;">6</div>
        <span class="mt-4 text-base font-semibold text-gray-800">未来展望</span>
      </div>
    </div>
  </div>
</div>
