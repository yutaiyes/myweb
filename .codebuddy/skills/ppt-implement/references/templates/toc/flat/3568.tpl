<!-- 
模板ID: 3568
模板名称: 扁平风-圆形徽标
适用场景: 友好扁平风目录页
设计特点: 大圆形纯色编号,白底清新,两列布局,扁平无阴影
-->
<div class="w-[1440px] h-[810px] relative overflow-hidden bg-white">
  <!-- 装饰大圆（背景） -->
  <div class="absolute -top-20 -right-20 w-[300px] h-[300px] rounded-full" style="background-color: #dbeafe;"></div>
  <div class="absolute -bottom-16 -left-16 w-[240px] h-[240px] rounded-full" style="background-color: #fef3c7;"></div>

  <!-- 主体内容 -->
  <div class="absolute inset-0 flex flex-col justify-center px-20 py-12 z-10">
    <!-- 标题区 -->
    <div class="mb-10 flex items-center gap-4">
      <div class="w-2 h-10 rounded-full" style="background-color: #0ea5e9;"></div>
      <div>
        <h2 class="text-4xl font-black text-gray-900">目录</h2>
        <p class="mt-1 text-xs font-medium tracking-[6px] text-gray-400 uppercase">Contents</p>
      </div>
    </div>

    <!-- 两列布局 -->
    <div class="grid grid-cols-2 gap-x-16 gap-y-6">
      <!-- 条目1 -->
      <div class="flex items-center gap-5">
        <div class="w-14 h-14 rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg" style="background-color: #0ea5e9;">1</div>
        <div>
          <span class="text-lg font-semibold text-gray-800">项目背景</span>
          <div class="mt-1 w-full h-px" style="background-color: #e5e7eb;"></div>
        </div>
      </div>
      <!-- 条目2 -->
      <div class="flex items-center gap-5">
        <div class="w-14 h-14 rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg" style="background-color: #f43f5e;">2</div>
        <div>
          <span class="text-lg font-semibold text-gray-800">核心功能</span>
          <div class="mt-1 w-full h-px" style="background-color: #e5e7eb;"></div>
        </div>
      </div>
      <!-- 条目3 -->
      <div class="flex items-center gap-5">
        <div class="w-14 h-14 rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg" style="background-color: #8b5cf6;">3</div>
        <div>
          <span class="text-lg font-semibold text-gray-800">技术架构</span>
          <div class="mt-1 w-full h-px" style="background-color: #e5e7eb;"></div>
        </div>
      </div>
      <!-- 条目4 -->
      <div class="flex items-center gap-5">
        <div class="w-14 h-14 rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg" style="background-color: #f59e0b;">4</div>
        <div>
          <span class="text-lg font-semibold text-gray-800">实施计划</span>
          <div class="mt-1 w-full h-px" style="background-color: #e5e7eb;"></div>
        </div>
      </div>
      <!-- 条目5 -->
      <div class="flex items-center gap-5">
        <div class="w-14 h-14 rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg" style="background-color: #10b981;">5</div>
        <div>
          <span class="text-lg font-semibold text-gray-800">成果展示</span>
          <div class="mt-1 w-full h-px" style="background-color: #e5e7eb;"></div>
        </div>
      </div>
      <!-- 条目6 -->
      <div class="flex items-center gap-5">
        <div class="w-14 h-14 rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg" style="background-color: #6366f1;">6</div>
        <div>
          <span class="text-lg font-semibold text-gray-800">未来展望</span>
          <div class="mt-1 w-full h-px" style="background-color: #e5e7eb;"></div>
        </div>
      </div>
    </div>
  </div>
</div>
