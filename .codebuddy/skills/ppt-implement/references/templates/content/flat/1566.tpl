<!-- Template: 扁平风格-变体6 (Content #1566) - 数据仪表盘 -->
<div class="w-[1440px] h-[810px] relative overflow-hidden" style="background-color: #FFFFFF;">
    <!-- 顶部色条 -->
    <div class="absolute top-0 left-0 right-0 h-[6px] flex">
        <div class="flex-1" style="background-color: #2563EB;"></div>
        <div class="flex-1" style="background-color: #7C3AED;"></div>
        <div class="flex-1" style="background-color: #DC2626;"></div>
        <div class="flex-1" style="background-color: #059669;"></div>
    </div>
    <div class="absolute inset-0 flex flex-col px-14 py-10">
        <!-- 标题 -->
        <div class="flex items-end justify-between mb-6">
            <div>
                <h1 class="text-[38px] font-black" style="color: #111827;">数据仪表盘</h1>
                <p class="text-[13px] tracking-widest" style="color: #9CA3AF;">DATA DASHBOARD OVERVIEW</p>
            </div>
            <div class="px-4 py-2" style="background-color: #F3F4F6;">
                <p class="text-[13px] font-medium" style="color: #6B7280;">2024 年度报告</p>
            </div>
        </div>
        <!-- 4个指标卡 -->
        <div class="grid grid-cols-4 gap-4 mb-5">
            <div class="p-5" style="background-color: #2563EB;">
                <p class="text-[13px] font-medium mb-2" style="color: #BFDBFE;">月活跃用户</p>
                <p class="text-[32px] font-black text-white leading-none mb-1">2.4M</p>
                <p class="text-[13px]" style="color: #93C5FD;">+12.5% vs 上月</p>
            </div>
            <div class="p-5" style="background-color: #7C3AED;">
                <p class="text-[13px] font-medium mb-2" style="color: #DDD6FE;">转化率</p>
                <p class="text-[32px] font-black text-white leading-none mb-1">8.7%</p>
                <p class="text-[13px]" style="color: #C4B5FD;">+2.1% vs 上月</p>
            </div>
            <div class="p-5" style="background-color: #DC2626;">
                <p class="text-[13px] font-medium mb-2" style="color: #FECACA;">营收增长</p>
                <p class="text-[32px] font-black text-white leading-none mb-1">36%</p>
                <p class="text-[13px]" style="color: #FCA5A5;">+5.3% vs 上月</p>
            </div>
            <div class="p-5" style="background-color: #059669;">
                <p class="text-[13px] font-medium mb-2" style="color: #A7F3D0;">用户满意度</p>
                <p class="text-[32px] font-black text-white leading-none mb-1">94%</p>
                <p class="text-[13px]" style="color: #6EE7B7;">+1.8% vs 上月</p>
            </div>
        </div>
        <!-- 下半区：趋势 + 细分 -->
        <div class="flex-1 flex gap-5">
            <!-- 左侧趋势区 -->
            <div class="flex-1 p-6" style="background-color: #F9FAFB;">
                <h3 class="text-[20px] font-bold mb-4" style="color: #111827;">增长趋势分析</h3>
                <!-- 简易柱状图 -->
                <div class="flex items-end gap-3 h-[200px]">
                    <div class="flex-1 flex flex-col items-center justify-end gap-1">
                        <div class="w-full" style="height: 60%; background-color: #2563EB;"></div>
                        <span class="text-[12px]" style="color: #6B7280;">Q1</span>
                    </div>
                    <div class="flex-1 flex flex-col items-center justify-end gap-1">
                        <div class="w-full" style="height: 75%; background-color: #2563EB;"></div>
                        <span class="text-[12px]" style="color: #6B7280;">Q2</span>
                    </div>
                    <div class="flex-1 flex flex-col items-center justify-end gap-1">
                        <div class="w-full" style="height: 85%; background-color: #2563EB;"></div>
                        <span class="text-[12px]" style="color: #6B7280;">Q3</span>
                    </div>
                    <div class="flex-1 flex flex-col items-center justify-end gap-1">
                        <div class="w-full" style="height: 100%; background-color: #1D4ED8;"></div>
                        <span class="text-[12px]" style="color: #6B7280;">Q4</span>
                    </div>
                </div>
                <p class="text-[13px] mt-3" style="color: #9CA3AF;">数据来源：内部运营系统</p>
            </div>
            <!-- 右侧细分列表 -->
            <div class="w-[400px] flex-shrink-0 flex flex-col gap-3">
                <div class="flex items-center gap-4 p-4" style="background-color: #EFF6FF; border-left: 4px solid #2563EB;">
                    <div class="text-[20px] font-black" style="color: #2563EB;">45%</div>
                    <div><p class="text-[14px] font-bold" style="color: #111827;">移动端用户</p><p class="text-[12px]" style="color: #6B7280;">主要增长来源</p></div>
                </div>
                <div class="flex items-center gap-4 p-4" style="background-color: #FAF5FF; border-left: 4px solid #7C3AED;">
                    <div class="text-[20px] font-black" style="color: #7C3AED;">32%</div>
                    <div><p class="text-[14px] font-bold" style="color: #111827;">桌面端用户</p><p class="text-[12px]" style="color: #6B7280;">稳定增长</p></div>
                </div>
                <div class="flex items-center gap-4 p-4" style="background-color: #FFF1F2; border-left: 4px solid #DC2626;">
                    <div class="text-[20px] font-black" style="color: #DC2626;">15%</div>
                    <div><p class="text-[14px] font-bold" style="color: #111827;">平板端用户</p><p class="text-[12px]" style="color: #6B7280;">新增渠道</p></div>
                </div>
                <div class="flex items-center gap-4 p-4" style="background-color: #F0FDF4; border-left: 4px solid #059669;">
                    <div class="text-[20px] font-black" style="color: #059669;">8%</div>
                    <div><p class="text-[14px] font-bold" style="color: #111827;">其他终端</p><p class="text-[12px]" style="color: #6B7280;">IoT 设备等</p></div>
                </div>
            </div>
        </div>
    </div>
</div>