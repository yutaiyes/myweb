<!-- Template: 几何风格-变体5 (Content #1545) - 分层架构 -->
<div class="w-[1440px] h-[810px] relative overflow-hidden" style="background-color: #1E1B4B;">
    <div class="absolute inset-0 flex flex-col px-14 py-10">
        <!-- 标题 -->
        <div class="text-center mb-6">
            <h1 class="text-[38px] font-bold" style="color: #FFFFFF;">立体架构</h1>
            <p class="text-[14px]" style="color: #A5B4FC;">分层架构的模块化设计</p>
        </div>
        <!-- 三层架构 flex布局 -->
        <div class="flex-1 flex flex-col gap-5 justify-center px-10">
            <!-- 表现层 -->
            <div class="flex items-center gap-4">
                <p class="text-[13px] w-[60px] text-right flex-shrink-0" style="color: #A5B4FC;">表现层</p>
                <div class="flex-1 flex justify-center">
                    <div class="rounded-lg px-10 py-5 text-center" style="background-color: #4338CA;">
                        <p class="text-[18px] font-bold" style="color: #FFFFFF;">前端应用层</p>
                        <p class="text-[13px]" style="color: #C7D2FE;">Web / Mobile / Desktop</p>
                    </div>
                </div>
            </div>
            <!-- 连接线 -->
            <div class="flex justify-center">
                <svg class="w-4 h-8" viewBox="0 0 16 32"><line x1="8" y1="0" x2="8" y2="32" stroke="#6366F1" stroke-width="2" stroke-dasharray="4,3"/></svg>
            </div>
            <!-- 服务层 -->
            <div class="flex items-center gap-4">
                <p class="text-[13px] w-[60px] text-right flex-shrink-0" style="color: #A5B4FC;">服务层</p>
                <div class="flex-1 flex justify-center gap-5">
                    <div class="flex-1 rounded-lg px-5 py-4 text-center" style="background-color: #3730A3;">
                        <p class="text-[16px] font-bold" style="color: #FFFFFF;">用户服务</p>
                        <p class="text-[12px]" style="color: #C7D2FE;">认证 / 权限</p>
                    </div>
                    <div class="flex-1 rounded-lg px-5 py-4 text-center" style="background-color: #312E81;">
                        <p class="text-[16px] font-bold" style="color: #FFFFFF;">业务逻辑层</p>
                        <p class="text-[12px]" style="color: #C7D2FE;">核心业务处理</p>
                    </div>
                    <div class="flex-1 rounded-lg px-5 py-4 text-center" style="background-color: #3730A3;">
                        <p class="text-[16px] font-bold" style="color: #FFFFFF;">API网关</p>
                        <p class="text-[12px]" style="color: #C7D2FE;">路由 / 限流</p>
                    </div>
                </div>
            </div>
            <!-- 连接线 -->
            <div class="flex justify-center">
                <svg class="w-4 h-8" viewBox="0 0 16 32"><line x1="8" y1="0" x2="8" y2="32" stroke="#6366F1" stroke-width="2" stroke-dasharray="4,3"/></svg>
            </div>
            <!-- 数据层 -->
            <div class="flex items-center gap-4">
                <p class="text-[13px] w-[60px] text-right flex-shrink-0" style="color: #A5B4FC;">数据层</p>
                <div class="flex-1 flex justify-center gap-4">
                    <div class="flex-1 rounded-lg px-4 py-4 text-center" style="background-color: #4338CA; opacity: 0.8;">
                        <p class="text-[14px] font-bold" style="color: #FFFFFF;">数据库</p>
                        <p class="text-[11px]" style="color: #C7D2FE;">MySQL / PostgreSQL</p>
                    </div>
                    <div class="flex-1 rounded-lg px-4 py-4 text-center" style="background-color: #3730A3; opacity: 0.8;">
                        <p class="text-[14px] font-bold" style="color: #FFFFFF;">缓存</p>
                        <p class="text-[11px]" style="color: #C7D2FE;">Redis / Memcached</p>
                    </div>
                    <div class="flex-1 rounded-lg px-4 py-4 text-center" style="background-color: #312E81; opacity: 0.8;">
                        <p class="text-[14px] font-bold" style="color: #FFFFFF;">消息队列</p>
                        <p class="text-[11px]" style="color: #C7D2FE;">Kafka / RabbitMQ</p>
                    </div>
                    <div class="flex-1 rounded-lg px-4 py-4 text-center" style="background-color: #1E1B4B; border: 1px solid #4338CA;">
                        <p class="text-[14px] font-bold" style="color: #FFFFFF;">存储服务</p>
                        <p class="text-[11px]" style="color: #C7D2FE;">OSS / MinIO</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
