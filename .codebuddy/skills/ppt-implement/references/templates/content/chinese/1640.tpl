                    <span class="text-[22px] font-serif" style="color: #C4A882;">2500<span class="text-[12px] ml-1" style="color: #7A6B5D;">年</span></span>
                </div>
                <div class="flex items-center justify-between py-3 px-4" style="border-top: 1px solid #3A332A;">
                    <span class="text-[14px]" style="color: #B8A99A;">经典典籍</span>
                    <span class="text-[22px] font-serif" style="color: #C4A882;">1400<span class="text-[12px] ml-1" style="color: #7A6B5D;">余部</span></span>
                </div>
                <div class="flex items-center justify-between py-3 px-4" style="border-top: 1px solid #3A332A; border-bottom: 1px solid #3A332A;">
                    <span class="text-[14px]" style="color: #B8A99A;">道教名山</span>
                    <span class="text-[22px] font-serif" style="color: #C4A882;">36<span class="text-[12px] ml-1" style="color: #7A6B5D;">洞天</span></span>
                </div>
            </div>

            <!-- 印章 -->
            <div class="mt-10 w-14 h-14 flex items-center justify-center" style="border: 2px solid #7A1B1B;">
                <span class="text-[18px] font-serif" style="color: #7A1B1B;">道</span>
            </div>
        </div>

        <!-- 右侧内容区 -->
        <div class="flex-1 flex flex-col">
            <div class="flex-1 flex flex-col justify-center px-16 gap-6">
                <!-- 第一段 -->
                <div class="flex gap-6">
                    <div class="flex-1 p-6" style="background-color: #F0EBE1;">
                        <div class="flex items-center gap-3 mb-4">
                            <span class="text-[30px] font-serif" style="color: #7A1B1B;">壹</span>
                            <div>
                                <h3 class="text-[20px] font-serif" style="color: #1F1A14;">无为而治</h3>
                                <p class="text-[12px]" style="color: #7A6B5D;">Wu Wei</p>
                            </div>
                        </div>
                        <p class="text-[16px] leading-[1.8]" style="color: #4A3728;">
                            道家主张顺应自然规律，不妄为、不强为。无为并非不作为，而是不违背自然之道而刻意行事，使万物自然而然地发展。
                        </p>
                        <p class="text-[13px] mt-3 italic" style="color: #7A6B5D;">"无为而无不为" —— 《道德经》</p>
                    </div>
                </div>

                <!-- 第二段 -->
                <div class="flex gap-6">
                    <div class="w-[280px] p-6 flex-shrink-0" style="background-color: #1F1A14;">
                        <div class="flex items-center gap-3 mb-4">
