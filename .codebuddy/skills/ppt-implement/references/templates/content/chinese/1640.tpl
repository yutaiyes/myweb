            <p class="text-[12px] tracking-[4px] mb-6" style="color: #7A6B5D;">TAOISM</p>
            <h1 class="text-[42px] font-serif tracking-[6px] mb-4" style="color: #FAF9F6;">道法自然</h1>
            <div class="w-10 h-[1px] mb-6" style="background-color: #7A1B1B;"></div>
            <p class="text-[16px] font-serif leading-[2] text-center" style="color: #C4A882;">
