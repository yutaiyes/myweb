<!-- Template: 中国风格-变体17 (Content #1627) - 民间艺术·色块标题+双图+文字列表 -->
<div class="w-[1440px] h-[810px] relative overflow-hidden" style="background-color: #FAF9F6;">
    <!-- 顶部红色标题条 -->
    <div class="absolute top-0 left-0 right-0 h-[90px] flex items-center justify-between px-20" style="background-color: #7A1B1B;">
        <div class="flex items-center gap-4">
            <h1 class="text-[38px] font-serif" style="color: #F4E7D3;">民间艺术</h1>
            <span class="text-[14px] tracking-wide" style="color: #D4A574;">Folk Arts of China</span>
        </div>
        <p class="text-[14px]" style="color: #D4A574;">非物质文化遗产保护项目</p>
    </div>

    <!-- 主体区域 -->
    <div class="absolute top-[90px] bottom-0 left-0 right-0 flex px-20 py-10 gap-12">
        <!-- 左侧：介绍+图 -->
        <div class="w-[480px] flex flex-col gap-6">
            <p class="text-[16px] leading-[1.8]" style="color: #4A3728;">
                中国民间艺术源远流长，形式多样，承载着劳动人民的智慧与情感。从剪纸到刺绣，从泥塑到皮影，每一种艺术形式都凝聚着世代传承的文化记忆。
            </p>
            <!-- 一张图 -->
            <div class="flex-1 flex items-center justify-center overflow-hidden">
                <img src="/placeholder.svg" alt="民间艺术作品" style="width: 380px; height: 380px;" class="object-cover" />
            </div>
        </div>

        <!-- 右侧：六个分类卡片 -->
        <div class="flex-1 grid grid-cols-2 gap-4">
            <div class="p-5 flex flex-col" style="background-color: #F0EBE1;">
                <p class="text-[20px] font-serif mb-2" style="color: #7A1B1B;">剪纸</p>
                <p class="text-[14px] leading-relaxed" style="color: #7A6B5D;">以纸为材，以刀代笔，镂空造型，喜庆吉祥</p>
            </div>
            <div class="p-5 flex flex-col" style="background-color: #F0EBE1;">
                <p class="text-[20px] font-serif mb-2" style="color: #7A1B1B;">刺绣</p>
                <p class="text-[14px] leading-relaxed" style="color: #7A6B5D;">针为笔，线为墨，苏湘蜀粤四大名绣各领风骚</p>
            </div>
            <div class="p-5 flex flex-col" style="background-color: #1F1A14;">
                <p class="text-[20px] font-serif mb-2" style="color: #C4A882;">皮影</p>
                <p class="text-[14px] leading-relaxed" style="color: #7A6B5D;">光影之间，方寸舞台演绎千古悲欢离合</p>
            </div>
            <div class="p-5 flex flex-col" style="background-color: #F0EBE1;">
                <p class="text-[20px] font-serif mb-2" style="color: #7A1B1B;">陶瓷</p>
                <p class="text-[14px] leading-relaxed" style="color: #7A6B5D;">泥火淬炼，景德镇瓷器名扬天下千年不衰</p>
            </div>
            <div class="p-5 flex flex-col" style="background-color: #F0EBE1;">
                <p class="text-[20px] font-serif mb-2" style="color: #7A1B1B;">年画</p>
                <p class="text-[14px] leading-relaxed" style="color: #7A6B5D;">木版水印，色彩鲜艳，年节张贴祈福纳祥</p>
            </div>
            <div class="p-5 flex flex-col" style="background-color: #F0EBE1;">
                <p class="text-[20px] font-serif mb-2" style="color: #7A1B1B;">编织</p>
                <p class="text-[14px] leading-relaxed" style="color: #7A6B5D;">竹编草编棕编，经纬交错编织生活之美</p>
            </div>
        </div>
    </div>
</div>