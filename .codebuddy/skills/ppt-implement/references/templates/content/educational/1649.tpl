                <div class="w-8 h-[2px]" style="background-color: #DC2626;"></div>
                <div class="w-full space-y-3 text-center">
                    <div class="py-3 px-4" style="background-color: #FFFFFF;">
                        <p class="text-[13px] mb-1" style="color: #DC2626;">读音</p>
                        <p class="text-[22px] font-bold" style="color: #1E293B;">ji (三声)</p>
                    </div>
                    <div class="py-3 px-4" style="background-color: #FFFFFF;">
                        <p class="text-[13px] mb-1" style="color: #DC2626;">释义</p>
                        <p class="text-[16px]" style="color: #374151;">自己、自身</p>
                    </div>
                    <div class="py-3 px-4" style="background-color: #FFFFFF;">
                        <p class="text-[13px] mb-1" style="color: #DC2626;">组词</p>
                        <div class="flex justify-center gap-2">
                            <span class="px-3 py-1 text-[14px]" style="background-color: #FEF2F2; color: #374151;">自己</span>
                            <span class="px-3 py-1 text-[14px]" style="background-color: #FEF2F2; color: #374151;">知己</span>
                            <span class="px-3 py-1 text-[14px]" style="background-color: #FEF2F2; color: #374151;">克己</span>
                        </div>
                    </div>
                    <div class="py-2 px-4" style="background-color: #DC2626;">
                        <p class="text-[14px] font-semibold" style="color: #FFFFFF;">左不出头</p>
                    </div>
                </div>
            </div>

            <!-- 已 - 深色 -->
            <div class="flex-1 flex flex-col items-center justify-center px-8 gap-5" style="background-color: #1E293B;">
                <div class="w-[160px] h-[160px] flex flex-col items-center justify-center" style="background-color: #334155; border: 2px solid #3B82F6;">
                    <span class="text-[90px] font-serif leading-none" style="color: #3B82F6;">已</span>
                </div>
                <div class="w-8 h-[2px]" style="background-color: #3B82F6;"></div>
                <div class="w-full space-y-3 text-center">
                    <div class="py-3 px-4" style="background-color: #334155;">
                        <p class="text-[13px] mb-1" style="color: #60A5FA;">读音</p>
                        <p class="text-[22px] font-bold" style="color: #F1F5F9;">yi (三声)</p>
                    </div>
                    <div class="py-3 px-4" style="background-color: #334155;">
                        <p class="text-[13px] mb-1" style="color: #60A5FA;">释义</p>
                        <p class="text-[16px]" style="color: #CBD5E1;">已经、停止</p>
                    </div>
                    <div class="py-3 px-4" style="background-color: #334155;">
                        <p class="text-[13px] mb-1" style="color: #60A5FA;">组词</p>
                        <div class="flex justify-center gap-2">
                            <span class="px-3 py-1 text-[14px]" style="background-color: #475569; color: #CBD5E1;">已经</span>
