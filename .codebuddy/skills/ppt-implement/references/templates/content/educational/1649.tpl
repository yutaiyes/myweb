                            <span class="px-3 py-1 text-[14px]" style="background-color: #475569; color: #CBD5E1;">已知</span>
                        </div>
                    </div>
                    <div class="py-2 px-4" style="background-color: #3B82F6;">
                        <p class="text-[14px] font-semibold" style="color: #FFFFFF;">左边出头</p>
                    </div>
                </div>
            </div>

            <!-- 巳 - 浅色 -->
            <div class="flex-1 flex flex-col items-center justify-center px-8 gap-5" style="background-color: #F0FDF4;">
                <div class="w-[160px] h-[160px] flex flex-col items-center justify-center" style="background-color: #FFFFFF; border: 2px solid #16A34A;">
                    <span class="text-[90px] font-serif leading-none" style="color: #16A34A;">巳</span>
