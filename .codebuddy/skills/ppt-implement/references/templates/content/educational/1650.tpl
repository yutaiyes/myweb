<!-- Template: 教育风格-变体10 (Content #1650) - 趣味数学·图形认知 -->
<div class="w-[1440px] h-[810px] relative overflow-hidden" style="background-color: #F8F7F4;">
    <div class="absolute inset-0 flex flex-col">
        <!-- 顶部标题栏 -->
        <div class="h-[80px] flex items-center justify-between px-16" style="background-color: #2D3A8C;">
            <div class="flex items-center gap-6">
                <h1 class="text-[30px] font-bold" style="color: #FFFFFF;">认识基本图形</h1>
                <div class="w-[1px] h-8" style="background-color: rgba(255,255,255,0.2);"></div>
                <p class="text-[16px]" style="color: rgba(255,255,255,0.7);">平面图形 · 特征与识别</p>
            </div>
            <p class="text-[12px] tracking-[2px]" style="color: rgba(255,255,255,0.5);">GEOMETRY</p>
        </div>

        <!-- 四列图形卡片 -->
        <div class="flex-1 flex gap-0">
            <!-- 圆形 -->
            <div class="flex-1 flex flex-col items-center justify-center px-6 gap-5" style="background-color: #FEF2F2;">
                <div class="w-[120px] h-[120px] rounded-full" style="background-color: #DC2626;"></div>
                <h3 class="text-[22px] font-bold" style="color: #1E293B;">圆形</h3>
                <div class="w-full space-y-3">
                    <div class="py-3 px-4" style="background-color: #FFFFFF;">
                        <p class="text-[13px] mb-1" style="color: #DC2626;">特征</p>
                        <p class="text-[14px]" style="color: #374151;">没有角，没有边</p>
                    </div>
                    <div class="py-3 px-4" style="background-color: #FFFFFF;">
                        <p class="text-[13px] mb-1" style="color: #DC2626;">边数</p>
                        <p class="text-[22px] font-bold" style="color: #DC2626;">0</p>
                    </div>
                    <div class="py-3 px-4" style="background-color: #FFFFFF;">
                        <p class="text-[13px] mb-1" style="color: #DC2626;">生活实例</p>
                        <p class="text-[14px]" style="color: #374151;">气球、足球、橘子、月亮</p>
                    </div>
                </div>
            </div>

            <!-- 正方形 -->
            <div class="flex-1 flex flex-col items-center justify-center px-6 gap-5" style="background-color: #1E293B;">
                <div class="w-[110px] h-[110px]" style="background-color: #3B82F6;"></div>
                <h3 class="text-[22px] font-bold" style="color: #FFFFFF;">正方形</h3>
                <div class="w-full space-y-3">
                    <div class="py-3 px-4" style="background-color: #334155;">
                        <p class="text-[13px] mb-1" style="color: #60A5FA;">特征</p>
                        <p class="text-[14px]" style="color: #CBD5E1;">4条边一样长，4个直角</p>
                    </div>
                    <div class="py-3 px-4" style="background-color: #334155;">
                        <p class="text-[13px] mb-1" style="color: #60A5FA;">边数</p>
                        <p class="text-[22px] font-bold" style="color: #3B82F6;">4</p>
                    </div>
                    <div class="py-3 px-4" style="background-color: #334155;">
                        <p class="text-[13px] mb-1" style="color: #60A5FA;">生活实例</p>
                        <p class="text-[14px]" style="color: #CBD5E1;">魔方、窗户、棋盘格</p>
                    </div>
                </div>
            </div>

            <!-- 长方形 -->
            <div class="flex-1 flex flex-col items-center justify-center px-6 gap-5" style="background-color: #F0FDF4;">
                <div class="w-[140px] h-[90px]" style="background-color: #16A34A;"></div>
                <h3 class="text-[22px] font-bold" style="color: #1E293B;">长方形</h3>
                <div class="w-full space-y-3">
                    <div class="py-3 px-4" style="background-color: #FFFFFF;">
                        <p class="text-[13px] mb-1" style="color: #16A34A;">特征</p>
                        <p class="text-[14px]" style="color: #374151;">对边一样长，4个直角</p>
                    </div>
                    <div class="py-3 px-4" style="background-color: #FFFFFF;">
                        <p class="text-[13px] mb-1" style="color: #16A34A;">边数</p>
                        <p class="text-[22px] font-bold" style="color: #16A34A;">4</p>
                    </div>
                    <div class="py-3 px-4" style="background-color: #FFFFFF;">
                        <p class="text-[13px] mb-1" style="color: #16A34A;">生活实例</p>
                        <p class="text-[14px]" style="color: #374151;">手机、电视、书本、门</p>
                    </div>
                </div>
            </div>

            <!-- 三角形 -->
            <div class="flex-1 flex flex-col items-center justify-center px-6 gap-5" style="background-color: #1E293B;">
                <div class="w-0 h-0" style="border-left: 60px solid transparent; border-right: 60px solid transparent; border-bottom: 104px solid #EAB308;"></div>
                <h3 class="text-[22px] font-bold" style="color: #FFFFFF;">三角形</h3>
                <div class="w-full space-y-3">
                    <div class="py-3 px-4" style="background-color: #334155;">
                        <p class="text-[13px] mb-1" style="color: #FDE047;">特征</p>
                        <p class="text-[14px]" style="color: #CBD5E1;">3条边，3个角</p>
                    </div>
                    <div class="py-3 px-4" style="background-color: #334155;">
                        <p class="text-[13px] mb-1" style="color: #FDE047;">边数</p>
                        <p class="text-[22px] font-bold" style="color: #EAB308;">3</p>
                    </div>
                    <div class="py-3 px-4" style="background-color: #334155;">
                        <p class="text-[13px] mb-1" style="color: #FDE047;">生活实例</p>
                        <p class="text-[14px]" style="color: #CBD5E1;">帐篷、圣诞树、山峰</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- 底部互动区 -->
        <div class="h-[80px] flex items-center justify-center gap-16 px-16" style="background-color: #E8573A;">
            <div class="text-center">
                <p class="text-[14px]" style="color: #FFFFFF;">找一找：教室里有哪些图形？</p>
            </div>
            <div class="w-[1px] h-8" style="background-color: rgba(255,255,255,0.3);"></div>
            <div class="flex items-center gap-8">
                <div class="text-center">
                    <span class="text-[22px] font-bold" style="color: #FFFFFF;">4</span>
                    <p class="text-[12px]" style="color: rgba(255,255,255,0.7);">种基本图形</p>
                </div>
                <div class="text-center">
                    <span class="text-[22px] font-bold" style="color: #FFFFFF;">180</span>
                    <p class="text-[12px]" style="color: rgba(255,255,255,0.7);">度三角内角和</p>
                </div>
                <div class="text-center">
                    <span class="text-[22px] font-bold" style="color: #FFFFFF;">360</span>
                    <p class="text-[12px]" style="color: rgba(255,255,255,0.7);">度圆的角度</p>
                </div>
            </div>
        </div>
    </div>
</div>