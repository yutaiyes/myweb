<!-- Template: 教育风格-变体12 (Content #1652) - HTML入门·标签学习 -->
<div class="w-[1440px] h-[810px] relative overflow-hidden" style="background-color: #1E293B;">
    <div class="absolute inset-0 flex flex-col">
        <!-- 顶部标题栏 -->
        <div class="h-[80px] flex items-center justify-between px-16" style="background-color: #2D3A8C;">
            <div class="flex items-center gap-6">
                <h1 class="text-[32px] font-bold font-mono" style="color: #FFFFFF;">HTML 入门</h1>
                <div class="w-[1px] h-8" style="background-color: rgba(255,255,255,0.2);"></div>
                <p class="text-[16px] font-mono" style="color: rgba(255,255,255,0.7);">常用标签学习</p>
            </div>
            <p class="text-[12px] tracking-[2px]" style="color: rgba(255,255,255,0.5);">WEB DEVELOPMENT</p>
        </div>

        <!-- 主内容区 -->
        <div class="flex-1 flex px-16 py-8 gap-8">
            <!-- 左列 -->
            <div class="flex-1 space-y-4">
                <div class="p-5" style="background-color: #334155;">
                    <h3 class="text-[18px] font-bold font-mono mb-3" style="color: #E8573A;">&lt;h1&gt; 标题标签</h3>
                    <div class="p-3 font-mono text-[14px]" style="background-color: #1E293B;">
                        <span style="color: #64748B;">&lt;</span><span style="color: #F472B6;">h1</span><span style="color: #64748B;">&gt;</span><span style="color: #86EFAC;">我是一级标题</span><span style="color: #64748B;">&lt;/</span><span style="color: #F472B6;">h1</span><span style="color: #64748B;">&gt;</span>
                    </div>
                    <p class="text-[13px] mt-3" style="color: #94A3B8;">用于定义标题，h1到h6，数字越小标题越大</p>
                </div>

                <div class="p-5" style="background-color: #334155;">
                    <h3 class="text-[18px] font-bold font-mono mb-3" style="color: #E8573A;">&lt;p&gt; 段落标签</h3>
                    <div class="p-3 font-mono text-[14px]" style="background-color: #1E293B;">
                        <span style="color: #64748B;">&lt;</span><span style="color: #F472B6;">p</span><span style="color: #64748B;">&gt;</span><span style="color: #86EFAC;">这是一段文字</span><span style="color: #64748B;">&lt;/</span><span style="color: #F472B6;">p</span><span style="color: #64748B;">&gt;</span>
                    </div>
                    <p class="text-[13px] mt-3" style="color: #94A3B8;">用于定义段落，浏览器会自动添加间距</p>
                </div>

                <div class="p-5" style="background-color: #334155;">
                    <h3 class="text-[18px] font-bold font-mono mb-3" style="color: #E8573A;">&lt;a&gt; 链接标签</h3>
                    <div class="p-3 font-mono text-[14px]" style="background-color: #1E293B;">
                        <span style="color: #64748B;">&lt;</span><span style="color: #F472B6;">a</span> <span style="color: #93C5FD;">href</span>=<span style="color: #86EFAC;">"url"</span><span style="color: #64748B;">&gt;</span><span style="color: #FFFFFF;">点击跳转</span><span style="color: #64748B;">&lt;/</span><span style="color: #F472B6;">a</span><span style="color: #64748B;">&gt;</span>
                    </div>
                    <p class="text-[13px] mt-3" style="color: #94A3B8;">用于创建超链接，href属性指定跳转地址</p>
                </div>
            </div>

            <!-- 右列 -->
            <div class="flex-1 space-y-4">
                <div class="p-5" style="background-color: #334155;">
                    <h3 class="text-[18px] font-bold font-mono mb-3" style="color: #E8573A;">&lt;img&gt; 图片标签</h3>
                    <div class="p-3 font-mono text-[14px]" style="background-color: #1E293B;">
                        <span style="color: #64748B;">&lt;</span><span style="color: #F472B6;">img</span> <span style="color: #93C5FD;">src</span>=<span style="color: #86EFAC;">"path"</span> <span style="color: #93C5FD;">alt</span>=<span style="color: #86EFAC;">"desc"</span><span style="color: #64748B;">&gt;</span>
                    </div>
                    <p class="text-[13px] mt-3" style="color: #94A3B8;">用于插入图片，src是图片路径，alt是备用文字</p>
                </div>

                <div class="p-5" style="background-color: #334155;">
                    <h3 class="text-[18px] font-bold font-mono mb-3" style="color: #E8573A;">&lt;div&gt; 容器标签</h3>
                    <div class="p-3 font-mono text-[14px]" style="background-color: #1E293B;">
                        <span style="color: #64748B;">&lt;</span><span style="color: #F472B6;">div</span><span style="color: #64748B;">&gt;</span><span style="color: #86EFAC;">内容区域</span><span style="color: #64748B;">&lt;/</span><span style="color: #F472B6;">div</span><span style="color: #64748B;">&gt;</span>
                    </div>
                    <p class="text-[13px] mt-3" style="color: #94A3B8;">用于分组和布局，是最常用的容器标签</p>
                </div>

                <div class="p-5" style="background-color: #334155;">
                    <h3 class="text-[18px] font-bold font-mono mb-3" style="color: #E8573A;">&lt;ul&gt; 列表标签</h3>
                    <div class="p-3 font-mono text-[14px] space-y-0.5" style="background-color: #1E293B;">
                        <div><span style="color: #64748B;">&lt;</span><span style="color: #F472B6;">ul</span><span style="color: #64748B;">&gt;</span></div>
                        <div class="ml-4"><span style="color: #64748B;">&lt;</span><span style="color: #F472B6;">li</span><span style="color: #64748B;">&gt;</span><span style="color: #86EFAC;">列表项1</span><span style="color: #64748B;">&lt;/</span><span style="color: #F472B6;">li</span><span style="color: #64748B;">&gt;</span></div>
                        <div class="ml-4"><span style="color: #64748B;">&lt;</span><span style="color: #F472B6;">li</span><span style="color: #64748B;">&gt;</span><span style="color: #86EFAC;">列表项2</span><span style="color: #64748B;">&lt;/</span><span style="color: #F472B6;">li</span><span style="color: #64748B;">&gt;</span></div>
                        <div><span style="color: #64748B;">&lt;/</span><span style="color: #F472B6;">ul</span><span style="color: #64748B;">&gt;</span></div>
                    </div>
                    <p class="text-[13px] mt-3" style="color: #94A3B8;">用于创建无序列表，每项用li标签包裹</p>
                </div>
            </div>
        </div>

        <!-- 底部信息条 -->
        <div class="h-[44px] flex items-center justify-center" style="background-color: #E8573A;">
            <p class="text-[13px]" style="color: #FFFFFF;">参考：MDN Web Docs · HTML基础教程</p>
        </div>
    </div>
</div>