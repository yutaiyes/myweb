<!-- Template: 文艺风格-变体8 (Content #1558) - 仰望星空 -->
<div class="w-[1440px] h-[810px] relative overflow-hidden" style="background-color: #1C1917; font-family: 'Georgia', serif;">
    <div class="absolute top-0 left-0 right-0 h-[3px]" style="background-color: #B45309;"></div>
    <div class="absolute inset-0 flex flex-col px-14 py-10">
        <!-- 标题 -->
        <div class="text-center mb-6">
            <h1 class="text-[38px] font-bold" style="color: #FEFCE8;">仰望星空</h1>
            <p class="text-[13px]" style="color: #78716C;">Stargazing & Reflections</p>
        </div>
        <!-- 主内容 -->
        <div class="flex-1 flex gap-5">
