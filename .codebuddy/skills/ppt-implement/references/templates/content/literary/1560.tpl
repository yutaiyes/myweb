<!-- Template: 文艺风格-变体10 (Content #1560) - 浪漫情怀 -->
<div class="w-[1440px] h-[810px] relative overflow-hidden" style="background-color: #FFF1F2; font-family: 'Georgia', serif;">
    <div class="absolute top-0 left-0 right-0 h-[3px]" style="background-color: #9D174D;"></div>
    <div class="absolute inset-0 flex flex-col px-14 py-10">
        <!-- 标题 -->
        <div class="text-center mb-5">
            <p class="text-[13px] mb-2" style="color: #9D174D;">Love Letter</p>
            <h1 class="text-[38px] font-bold" style="color: #831843;">浪漫情怀</h1>
