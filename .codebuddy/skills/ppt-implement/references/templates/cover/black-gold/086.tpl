<!-- Template: 黑金风-璀璨水晶 (Cover #086) -->
<div class="cover-wrapper relative w-[1440px] h-[810px]">
  <div class="absolute top-0 left-0 w-[1440px] h-[810px] bg-[#0a0a0a] overflow-hidden">
    <!-- 水晶六边形装饰 - 右上角 -->
    <div class="absolute top-[60px] right-[100px] w-[80px] h-[80px] border-2 border-yellow-500/20" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>
    <div class="absolute top-[70px] right-[110px] w-[60px] h-[60px] border border-yellow-500/12" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>

    <!-- 水晶六边形装饰 - 左下角 -->
    <div class="absolute bottom-[70px] left-[80px] w-[70px] h-[70px] border-2 border-yellow-500/18" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>
    <div class="absolute bottom-[78px] left-[88px] w-[54px] h-[54px] border border-yellow-500/10" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>

    <!-- 散布装饰圆点 - 模拟闪光 -->
    <div class="absolute top-[120px] left-[180px] w-[4px] h-[4px] bg-yellow-500/25 rounded-full"></div>
    <div class="absolute top-[200px] left-[350px] w-[3px] h-[3px] bg-yellow-500/18 rounded-full"></div>
    <div class="absolute top-[90px] right-[300px] w-[4px] h-[4px] bg-yellow-500/20 rounded-full"></div>
    <div class="absolute bottom-[150px] right-[200px] w-[4px] h-[4px] bg-yellow-500/25 rounded-full"></div>
    <div class="absolute bottom-[120px] left-[300px] w-[3px] h-[3px] bg-yellow-500/18 rounded-full"></div>
    <div class="absolute bottom-[200px] right-[350px] w-[3px] h-[3px] bg-yellow-500/15 rounded-full"></div>

    <!-- 十字闪光 -->
    <div class="absolute top-[250px] left-[100px]">
      <div class="absolute w-[16px] h-[1px] bg-yellow-500/15 -translate-x-1/2"></div>
      <div class="absolute w-[1px] h-[16px] bg-yellow-500/15 -translate-y-1/2"></div>
    </div>
    <div class="absolute bottom-[230px] right-[120px]">
