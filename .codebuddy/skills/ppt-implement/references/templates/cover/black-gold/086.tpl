    <div class="absolute bottom-[30px] right-[30px] w-[50px] h-[50px] border-b-2 border-r-2 border-yellow-500/15"></div>

    <!-- 主内容区 -->
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="text-center max-w-[900px] px-20">
        <h1 class="text-[5.5rem] font-bold text-yellow-500 mb-8 leading-tight">高端晚宴邀请</h1>
        <p class="text-3xl text-[#d4af37]/80 font-light mb-12">珍馐美馔·名流雅集·尊贵时光</p>
        <div class="flex justify-center gap-3 mb-12">
