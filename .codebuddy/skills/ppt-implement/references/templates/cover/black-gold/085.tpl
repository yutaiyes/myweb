<!-- Template: 黑金风-金属质感 (Cover #085) -->
<div class="cover-wrapper relative w-[1440px] h-[810px]">
  <div class="absolute top-0 left-0 w-[1440px] h-[810px] bg-[#111111] overflow-hidden">
    <!-- 金属反光效果 - 用斜向实色条模拟 -->
    <div class="absolute top-0 left-[25%] w-[300px] h-full bg-yellow-500/[0.02] -skew-x-12"></div>

    <!-- 金色横线装饰 - 居中加亮 -->
    <div class="absolute top-[25%] left-[200px] right-[200px] h-[1px] bg-yellow-500/15"></div>
    <div class="absolute top-[25%] left-[50%] -translate-x-1/2 w-[300px] h-[1px] bg-yellow-500/35"></div>
    <div class="absolute top-[calc(25%-3px)] left-[50%] -translate-x-1/2 w-[6px] h-[6px] rounded-full bg-yellow-500/20"></div>

    <div class="absolute bottom-[25%] left-[250px] right-[250px] h-[1px] bg-yellow-500/12"></div>
    <div class="absolute bottom-[25%] left-[50%] -translate-x-1/2 w-[250px] h-[1px] bg-yellow-500/30"></div>
    <div class="absolute bottom-[calc(25%-3px)] left-[50%] -translate-x-1/2 w-[6px] h-[6px] rounded-full bg-yellow-500/18"></div>

    <!-- 左右装饰竖条 -->
    <div class="absolute top-[50%] left-[50px] -translate-y-1/2 w-[2px] h-[180px] bg-yellow-500/20"></div>
    <div class="absolute top-[50%] left-[58px] -translate-y-1/2 w-[1px] h-[120px] bg-yellow-500/10"></div>

    <div class="absolute top-[50%] right-[50px] -translate-y-1/2 w-[2px] h-[180px] bg-yellow-500/20"></div>
    <div class="absolute top-[50%] right-[58px] -translate-y-1/2 w-[1px] h-[120px] bg-yellow-500/10"></div>

    <!-- 竖条端点圆点 -->
    <div class="absolute top-[calc(50%-93px)] left-[48px] w-[6px] h-[6px] rounded-full bg-yellow-500/15"></div>
    <div class="absolute top-[calc(50%+87px)] left-[48px] w-[6px] h-[6px] rounded-full bg-yellow-500/15"></div>
    <div class="absolute top-[calc(50%-93px)] right-[48px] w-[6px] h-[6px] rounded-full bg-yellow-500/15"></div>
    <div class="absolute top-[calc(50%+87px)] right-[48px] w-[6px] h-[6px] rounded-full bg-yellow-500/15"></div>

    <!-- 四角装饰 -->
    <div class="absolute top-[35px] left-[35px] w-[40px] h-[40px] border-t-2 border-l-2 border-yellow-500/15"></div>
    <div class="absolute top-[35px] right-[35px] w-[40px] h-[40px] border-t-2 border-r-2 border-yellow-500/15"></div>
    <div class="absolute bottom-[35px] left-[35px] w-[40px] h-[40px] border-b-2 border-l-2 border-yellow-500/15"></div>
    <div class="absolute bottom-[35px] right-[35px] w-[40px] h-[40px] border-b-2 border-r-2 border-yellow-500/15"></div>

    <!-- 主内容区 -->
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="text-center max-w-[900px] px-20">
        <h1 class="text-[5.5rem] font-bold text-yellow-500 mb-8 leading-tight">名车品鉴盛宴</h1>
        <p class="text-3xl text-[#c9a961] font-light mb-12">顶级座驾·卓越性能·尊享驾驭</p>
        <div class="flex items-center justify-center gap-4 mb-12">
          <div class="w-[40px] h-[2px] bg-yellow-500/30"></div>
          <div class="w-[8px] h-[8px] border border-yellow-500/30 rotate-45"></div>
          <div class="w-[40px] h-[2px] bg-yellow-500/30"></div>
        </div>
        <div class="text-gray-500 text-xl">汽车事业部 | 新车发布会</div>
      </div>
    </div>
  </div>
</div>
