        <div class="absolute top-[80px] right-[100px] w-[32px] h-[32px] rotate-45" style="background-color: #FFD93D;"></div>
        <div class="absolute bottom-[80px] left-[100px] w-[24px] h-[24px] rounded-full" style="background-color: #FECACA;"></div>
        <!-- 主内容区 -->
        <div class="relative z-10 text-center">
            <!-- 帐篷图标（CSS绘制） -->
            <div class="mx-auto mb-8 relative" style="width: 80px; height: 70px;">
                <div class="absolute bottom-0 left-0 w-0 h-0" style="border-left: 40px solid transparent; border-right: 40px solid transparent; border-bottom: 70px solid #FF6B6B;"></div>
                <div class="absolute bottom-0 left-[20px] w-0 h-0" style="border-left: 20px solid transparent; border-right: 20px solid transparent; border-bottom: 35px solid white;"></div>
                <div class="absolute top-[-8px] left-1/2 -translate-x-1/2 w-[12px] h-[12px] rounded-full" style="background-color: #FFD93D;"></div>
            </div>
            <h1 class="text-[72px] font-black mb-4 leading-tight" style="color: #8B5CF6;">欢乐时光</h1>
            <p class="text-[26px] font-bold" style="color: #4B5563;">Happy Time Together!</p>
        </div>
    </div>
</div>
