<!-- Template: 卡通风-彩虹边框 (Cover #013) -->
<div class="cover-wrapper relative w-[1440px] h-[810px] relative">
    <div class="absolute top-0 left-0 w-[1440px] h-[810px] relative flex items-center justify-center overflow-hidden bg-white">
        <!-- 彩色边框（用四条实色边拼接） -->
        <div class="absolute top-[24px] left-[24px] right-[24px] h-[8px] rounded-full" style="background-color: #FF6B6B;"></div>
        <div class="absolute bottom-[24px] left-[24px] right-[24px] h-[8px] rounded-full" style="background-color: #6BCF7F;"></div>
        <div class="absolute top-[24px] left-[24px] w-[8px] bottom-[24px] rounded-full" style="background-color: #A78BFA;"></div>
        <div class="absolute top-[24px] right-[24px] w-[8px] bottom-[24px] rounded-full" style="background-color: #4ECDC4;"></div>
        <!-- 四角彩色圆点 -->
        <div class="absolute top-[16px] left-[16px] w-[24px] h-[24px] rounded-full" style="background-color: #FFD93D;"></div>
        <div class="absolute top-[16px] right-[16px] w-[24px] h-[24px] rounded-full" style="background-color: #FF6B6B;"></div>
        <div class="absolute bottom-[16px] left-[16px] w-[24px] h-[24px] rounded-full" style="background-color: #4ECDC4;"></div>
        <div class="absolute bottom-[16px] right-[16px] w-[24px] h-[24px] rounded-full" style="background-color: #A78BFA;"></div>
