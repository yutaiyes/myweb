const args = parseArgs(process.argv.slice(2));

if (args.help) {
  console.log(HELP_TEXT);
  process.exit(0);
}

if (args.version) {
  console.log(VERSION);
  process.exit(0);
}

// Resolve input/output paths
let INPUT_FILE, OUTPUT_FILE;

if (args.repoRoot) {
  // Use --repo-root to auto-detect paths
  const paths = resolveFromRepoRoot(args.repoRoot);
  INPUT_FILE = paths.input;
  OUTPUT_FILE = paths.output;
} else if (args.input && args.output) {
  // Use explicit --input and --output
  INPUT_FILE = path.resolve(args.input);
  OUTPUT_FILE = path.resolve(args.output);
} else {
  console.error('Error: Either --repo-root OR both --input and --output are required\n');
  console.log(HELP_TEXT);
  process.exit(1);
}

const OUTPUT_DIR = path.dirname(OUTPUT_FILE);

/**
 * Main function
 */
function main() {
  // Check if input file exists
  if (!fs.existsSync(INPUT_FILE)) {
    console.error(`Error: Input file not found at ${INPUT_FILE}`);
    process.exit(1);
  }
  
  console.log(`Compiling styles from: ${INPUT_FILE}`);
  
  // Read CSS/SCSS file
  const cssContent = fs.readFileSync(INPUT_FILE, 'utf-8');
  
  // Parse variables based on file type
  let variables;
  if (INPUT_FILE.endsWith('.scss')) {
    // Miniprogram SCSS file
    variables = parseScssVariables(cssContent);
    console.log('Detected SCSS file, using miniprogram style parsing');
  } else {
    // Web CSS file with CSS variables
    variables = parseCssVariables(cssContent);
  }
  
  const rootVarCount = Object.keys(variables.root).length;
  const darkVarCount = Object.keys(variables.dark).length;
  
  if (rootVarCount === 0 && !INPUT_FILE.endsWith('.scss')) {
    // Only warn for CSS files, SCSS files use different variable format
    console.warn('Warning: No :root variables found in CSS file');
  }
  
  console.log(`Found ${rootVarCount} :root variables, ${darkVarCount} .dark variables`);
  
  // Generate HTML
  const htmlContent = generateStyleGuideHtml(variables);
  
  // Ensure output directory exists
  if (!fs.existsSync(OUTPUT_DIR)) {
    fs.mkdirSync(OUTPUT_DIR, { recursive: true });
  }
  
  // Write output
  fs.writeFileSync(OUTPUT_FILE, htmlContent);
  
  console.log(`Successfully generated ${OUTPUT_FILE}`);
  
  // Print summary of variables
  console.log('\nCompiled variables:');
  console.log('  :root variables:');
  const rootCategories = ['primary', 'background', 'foreground', 'card', 'muted', 'accent', 'destructive', 'success', 'warning', 'info'];
  for (const cat of rootCategories) {
    if (variables.root[cat]) {
      console.log(`    --${cat}: ${variables.root[cat]}`);
    }
  }
  if (darkVarCount > 0) {
    console.log('  .dark variables:');
    for (const cat of rootCategories) {
      if (variables.dark[cat]) {
        console.log(`    --${cat}: ${variables.dark[cat]}`);
      }
    }
  }
}

main();
