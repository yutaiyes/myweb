#!/usr/bin/env node

import * as fs from 'fs';
import * as path from 'path';

const VERSION = '1.0.0';

const HELP_TEXT = `
compile-styles v${VERSION}

Compile CSS variables from index.css to style-guide.html

Usage:
  compile-styles --repo-root <path>
  compile-styles -i <input> -o <output>
  compile-styles -h, --help
  compile-styles -v, --version

Options:
  -r, --repo-root <path>  Project root directory. Reads docs/project.json to
                          determine project type and auto-configure paths.
                          Currently supports: web
                            - web: input=frontend/src/index.css, 
                                   output=docs/design/default.style-guide.html
  -i, --input <path>      Path to index.css file
  -o, --output <path>     Path to output style-guide.html file
  -t, --template <path>   Path to template HTML file (optional)
  -h, --help              Show this help message
  -v, --version           Show version

Note: Either --repo-root OR both --input and --output are required.

Example:
  compile-styles --repo-root /path/to/project
  compile-styles -r .
  compile-styles -i ./src/index.css -o ./docs/design/style-guide.html
`;

/**
 * Parse command line arguments
 */
function parseArgs(args) {
  const result = {
    input: null,
    output: null,
    template: null,
    repoRoot: null,
    help: false,
    version: false
  };

  for (let i = 0; i < args.length; i++) {
    const arg = args[i];
    
    if (arg === '-h' || arg === '--help') {
      result.help = true;
    } else if (arg === '-v' || arg === '--version') {
      result.version = true;
    } else if (arg === '-i' || arg === '--input') {
      result.input = args[++i];
    } else if (arg === '-o' || arg === '--output') {
      result.output = args[++i];
    } else if (arg === '-t' || arg === '--template') {
      result.template = args[++i];
    } else if (arg === '-r' || arg === '--repo-root') {
      result.repoRoot = args[++i];
    }
  }

  return result;
}

/**
 * Project type configurations
 * Maps project_type to input/output paths relative to repo root
 */
const PROJECT_TYPE_CONFIG = {
  web: {
    input: 'frontend/src/index.css',
    output: 'docs/design/default.style-guide.html'
  },
  miniprogram: {
    input: 'frontend/src/app.scss',
    output: 'docs/design/default.style-guide.html'
  },
  prototype: {
    input: 'frontend/src/index.css',
    output: 'docs/design/default.style-guide.html'
  }
};

/**
 * Resolve paths from --repo-root option
 * Reads docs/project.json to determine project type
 */
function resolveFromRepoRoot(repoRoot) {
  const resolvedRoot = path.resolve(repoRoot);
  const projectJsonPath = path.join(resolvedRoot, 'docs', 'project.json');
  
  if (!fs.existsSync(projectJsonPath)) {
    console.error(`Error: docs/project.json not found at ${projectJsonPath}`);
    process.exit(1);
  }
  
  let projectConfig;
  try {
    const content = fs.readFileSync(projectJsonPath, 'utf-8');
    projectConfig = JSON.parse(content);
  } catch (e) {
    console.error(`Error: Failed to parse docs/project.json: ${e.message}`);
    process.exit(1);
  }
  
  const projectType = projectConfig.project_type;
  
  if (!projectType) {
    console.error('Error: project_type not found in docs/project.json');
    process.exit(1);
  }
  
  const config = PROJECT_TYPE_CONFIG[projectType];
  
  if (!config) {
    console.error(`Error: Unsupported project_type "${projectType}". Supported types: ${Object.keys(PROJECT_TYPE_CONFIG).join(', ')}`);
    process.exit(1);
  }
  
  console.log(`Detected project type: ${projectType}`);
  
  return {
    input: path.join(resolvedRoot, config.input),
    output: path.join(resolvedRoot, config.output)
  };
}

/**
 * Parse CSS variables from index.css content
 * Extracts :root and .dark variables
 */
function parseCssVariables(cssContent) {
  const variables = {
    root: {},
    dark: {}
  };

  // Parse :root variables
  const rootMatch = cssContent.match(/:root\s*\{([^}]+)\}/s);
  if (rootMatch) {
    const rootContent = rootMatch[1];
    const varMatches = rootContent.matchAll(/--([a-zA-Z0-9-]+)\s*:\s*([^;]+);/g);
    for (const match of varMatches) {
      variables.root[match[1]] = match[2].trim();
    }
  }

  // Parse .dark variables
  const darkMatch = cssContent.match(/\.dark\s*\{([^}]+)\}/s);
  if (darkMatch) {
    const darkContent = darkMatch[1];
    const varMatches = darkContent.matchAll(/--([a-zA-Z0-9-]+)\s*:\s*([^;]+);/g);
    for (const match of varMatches) {
      variables.dark[match[1]] = match[2].trim();
    }
  }

  return variables;
}

/**
 * Parse SCSS variables from miniprogram app.scss
 * Extracts color values and converts them to CSS variables format
 */
function parseScssVariables(scssContent) {
  const variables = {
    root: {},
    dark: {}
  };
  
  // Extract colors from common patterns in SCSS
  // Look for color values in page, .container, etc.
  
  // Extract background-color from page
  const pageBgMatch = scssContent.match(/page\s*\{[^}]*background-color\s*:\s*([^;]+);/s);
  if (pageBgMatch) {
    variables.root['background'] = pageBgMatch[1].trim();
  }
  
  // Extract color from page (text color)
  const pageColorMatch = scssContent.match(/page\s*\{[^}]*[^-]color\s*:\s*([^;]+);/s);
  if (pageColorMatch) {
    variables.root['foreground'] = pageColorMatch[1].trim();
  }
  
  // Extract font-size from page
  const fontSizeMatch = scssContent.match(/page\s*\{[^}]*font-size\s*:\s*([^;]+);/s);
  if (fontSizeMatch) {
    variables.root['font-size-body'] = fontSizeMatch[1].trim();
  }
  
  // WeChat green as primary color for miniprogram
  variables.root['primary'] = '#07C160';
  variables.root['primary-foreground'] = '#ffffff';
  
  // Card background (typically white)
  variables.root['card'] = '#ffffff';
  variables.root['card-foreground'] = '#333333';
  
  // Muted colors
  variables.root['muted'] = '#f5f5f5';
  variables.root['muted-foreground'] = '#666666';
  
  // Border
  variables.root['border'] = '#e5e5e5';
  
  // Functional colors
  variables.root['success'] = '#07C160';
  variables.root['warning'] = '#FFC107';
  variables.root['destructive'] = '#FA5151';
  variables.root['info'] = '#10AEFF';
  
  // Radius
  variables.root['radius'] = '8px';
  
  return variables;
}

/**
 * Generate CSS variables block for style-guide.html
 */
function generateCssVariablesBlock(variables) {
  let css = '';
  
  // Generate :root block
  css += '    :root {\n';
  
  // Group variables by category
  const categories = {
    'radius': ['radius', 'radius-sm', 'radius-md', 'radius-lg', 'radius-xl', 'radius-full'],
    'background': ['background', 'foreground'],
    'card': ['card', 'card-foreground'],
    'popover': ['popover', 'popover-foreground'],
    'primary': ['primary', 'primary-foreground'],
    'secondary': ['secondary', 'secondary-foreground'],
    'muted': ['muted', 'muted-foreground'],
    'accent': ['accent', 'accent-foreground'],
    'destructive': ['destructive'],
    'border': ['border', 'input', 'ring'],
    'functional': ['success', 'success-foreground', 'warning', 'warning-foreground', 'info', 'info-foreground'],
    'theme': ['theme-red', 'theme-green', 'theme-gold', 'theme-blue'],
    'chart': ['chart-1', 'chart-2', 'chart-3', 'chart-4', 'chart-5'],
    'sidebar': ['sidebar', 'sidebar-foreground', 'sidebar-primary', 'sidebar-primary-foreground', 'sidebar-accent', 'sidebar-accent-foreground', 'sidebar-border', 'sidebar-ring'],
    'hero': ['hero', 'hero-foreground']
  };

  const categoryComments = {
    'radius': '/* === 圆角基准值 === */',
    'background': '/* === 背景颜色 === */',
    'card': '/* === 卡片 === */',
    'popover': '/* === 弹出层 === */',
    'primary': '/* === 主色调 === */',
    'secondary': '/* === 次要色 === */',
    'muted': '/* === 柔和色 === */',
    'accent': '/* === 强调色 === */',
    'destructive': '/* === 危险/错误色 === */',
    'border': '/* === 边框和输入框 === */',
    'functional': '/* === 功能颜色 === */',
    'theme': '/* === 主题特色颜色 === */',
    'chart': '/* === 图表颜色 === */',
    'sidebar': '/* === 侧边栏 === */',
    'hero': '/* === Hero 区域 === */'
  };

  // Track which variables have been output
  const outputVars = new Set();

  for (const [category, varNames] of Object.entries(categories)) {
    const categoryVars = varNames.filter(name => variables.root[name] !== undefined);
    if (categoryVars.length > 0) {
      css += `      ${categoryComments[category]}\n`;
      for (const name of categoryVars) {
        css += `      --${name}: ${variables.root[name]};\n`;
        outputVars.add(name);
      }
      css += '\n';
    }
  }

  // Output any remaining variables not in categories
  const remainingVars = Object.keys(variables.root).filter(name => !outputVars.has(name));
  if (remainingVars.length > 0) {
    css += '      /* === 其他变量 === */\n';
    for (const name of remainingVars) {
      css += `      --${name}: ${variables.root[name]};\n`;
    }
    css += '\n';
  }

  css += '    }\n';

  // Generate .dark block
  css += '\n    /* ==================== Dark Mode === */\n';
  css += '    .dark {\n';

  outputVars.clear();

  for (const [category, varNames] of Object.entries(categories)) {
    const categoryVars = varNames.filter(name => variables.dark[name] !== undefined);
    if (categoryVars.length > 0) {
      css += `      ${categoryComments[category]}\n`;
      for (const name of categoryVars) {
        css += `      --${name}: ${variables.dark[name]};\n`;
        outputVars.add(name);
      }
      css += '\n';
    }
  }

  // Output any remaining dark variables
  const remainingDarkVars = Object.keys(variables.dark).filter(name => !outputVars.has(name));
  if (remainingDarkVars.length > 0) {
    css += '      /* === 其他变量 === */\n';
    for (const name of remainingDarkVars) {
      css += `      --${name}: ${variables.dark[name]};\n`;
    }
    css += '\n';
  }

  css += '    }';

  return css;
}

