{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST http://localhost:55221/__genie__/restart > /dev/null 2>&1"
          },
          {
            "type": "command",
            "command": "./.codebuddy/genie/parse-routes -r . > /dev/null 2>&1"
          },
          {
            "type": "command",
            "command": "./.codebuddy/genie/compile-css-vars -r . > /dev/null 2>&1"
          },
          {
            "type": "command",
            "command": "./.codebuddy/genie/compile-styles -r . > /dev/null 2>&1"
          },
          {
            "type": "command",
            "command": "python3 .genie/scripts/python/capture_screenshot.py docs/posters/app/app-poster.png > /dev/null 2>&1 &"
          },
          {
            "type": "command",
            "command": "node \".codebuddy/skills/ppt-implement/scripts/export-ppt.js\" \".codebuddy\" \"${CODEBUDDY_PROJECT_DIR}\" > /dev/null 2>&1"
          },
          {
            "type": "prompt",
            "prompt": "Check if code files were modified (via Edit, Write, MultiEdit, or Bash tools that write files) during this turn. Then check if `./.genie/scripts/bash/setup-info.sh` was called to update the version description.\n\nRules:\n- If code was changed but setup-info.sh was NOT called, return {\"ok\": false, \"reason\": \"You modified code but did not run setup-info.sh to update the version description. Please run: ./.genie/scripts/bash/setup-info.sh --name \\\"PROJECT_NAME\\\" --preview-type pc|mobile \\\"VERSION_DESCRIPTION\\\" where VERSION_DESCRIPTION is a concise summary (max 10 words, starts with an action verb) of what you changed.\"}\n- If no code files were changed, or setup-info.sh was already called, return {\"ok\": true}."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \".codebuddy/skills/ppt-implement/scripts/setup-project.js\" \".codebuddy\" \"${CODEBUDDY_PROJECT_DIR}\" \".templates\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \".codebuddy/skills/ppt-implement/scripts/post-slide.js\" \".\" \"${CODEBUDDY_PROJECT_DIR}\""
          }
        ]
      }
    ]
  }
}
